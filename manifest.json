{
  "framework": "Recipe Governance Framework",
  "framework_version": "3.5",
  "updated": "2026-07-20",
  "canonical_source": "github",
  "notion_control_surface": "https://app.notion.com/p/3a1e0391ce6381dfb6dfc3b0c9e2e612",
  "change_queue": "https://app.notion.com/p/466bfaf3d8ed43dfa0e6a4c28caae2ef",
  "note": "GitHub is canonical for file contents. Notion holds proposed changes only. Cowork is the sole writer.",
  "files": [
    {
      "id": "core",
      "file": "recipe_governance_core.md",
      "version": "3.5",
      "load_when": "Every recipe, dish, or cooking-method request",
      "always": true
    },
    {
      "id": "meal_workflow",
      "file": "recipe_governance_meal_workflow.md",
      "version": "3.5",
      "load_when": "Two or more components served together",
      "always": false
    },
    {
      "id": "vault_signals",
      "file": "recipe_governance_vault_signals.md",
      "version": "3.5",
      "load_when": "A Vault digest is active, or Vault retrieval shapes a recipe",
      "always": false
    },
    {
      "id": "vault_ops",
      "file": "recipe_governance_vault_ops.md",
      "version": "3.5",
      "load_when": "Creating, updating, or preparing a Vault entry",
      "always": false
    },
    {
      "id": "docx_protocol",
      "file": "recipe_output_docx_protocol.md",
      "version": "1.0",
      "load_when": "Generating a Word document, including any bare 'generate the document' request",
      "always": false
    },
    {
      "id": "html_protocol",
      "file": "recipe_output_html_protocol.md",
      "version": "1.3",
      "load_when": "Generating an HTML cooking sheet",
      "always": false
    },
    {
      "id": "wine_pairing",
      "file": "wine_pairing_cooking_reference.md",
      "version": "1.0",
      "load_when": "Wine, beverage, cellar, or pairing recommendation",
      "always": false
    }
  ]
}
